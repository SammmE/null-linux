#!/bin/sh
set -eu

TARGET_DISK="/dev/sda"
TARGET_PARTITION="${TARGET_DISK}1"
MOUNT_POINT="/mnt/target"

cleanup() {
    if mountpoint -q "$MOUNT_POINT"; then
        umount "$MOUNT_POINT"
    fi
    if mountpoint -q /mnt; then
        umount /mnt
    fi
}

trap cleanup EXIT

echo "WARNING: ${TARGET_DISK} will be erased."
echo "Press ENTER to continue or Ctrl+C to cancel."
read dummy

fdisk "$TARGET_DISK" <<'EOF'
o
n
p
1


a
1
w
EOF

mkfs.ext4 "$TARGET_PARTITION"
echo "[3/5] Mounting target..."
mount -t tmpfs tmpfs /mnt
mkdir -p "$MOUNT_POINT"
mount "$TARGET_PARTITION" "$MOUNT_POINT"

for dir in /bin /boot /etc /lib /root /sbin /usr /var; do
    cp -a "$dir" "$MOUNT_POINT/"
done

mkdir -p \
    "$MOUNT_POINT/dev" \
    "$MOUNT_POINT/dev/pts" \
    "$MOUNT_POINT/dev/shm" \
    "$MOUNT_POINT/proc" \
    "$MOUNT_POINT/sys" \
    "$MOUNT_POINT/tmp" \
    "$MOUNT_POINT/run" \
    "$MOUNT_POINT/mnt"

limine bios-install "$TARGET_DISK"

cat > "$MOUNT_POINT/boot/limine.conf" <<'EOF'
timeout: 3

/Null Linux
    protocol: linux
    kernel_path: boot():/boot/vmlinuz
    module_path: boot():/boot/initramfs.cpio.gz
    cmdline: root=/dev/sda1 rootfstype=ext4 rw console=tty0 console=ttyS0
EOF

cat > "$MOUNT_POINT/etc/fstab" <<'EOF'
# <fs>        <mountpoint>  <type>   <opts>                          <dump> <pass>
/dev/sda1     /             ext4     defaults                        0      1
proc          /proc         proc     nosuid,nodev,noexec             0      0
sysfs         /sys          sysfs    nosuid,nodev,noexec             0      0
devtmpfs      /dev          devtmpfs mode=0755,nosuid                0      0
devpts        /dev/pts      devpts   gid=4,mode=620,nosuid,noexec    0      0
tmpfs         /run          tmpfs    mode=0755,nosuid,nodev          0      0
tmpfs         /tmp          tmpfs    mode=1777,nosuid,nodev          0      0
EOF

sync
umount "$MOUNT_POINT"
umount /mnt

trap - EXIT
echo "Null Linux installation complete. You can now reboot from ${TARGET_DISK}."
